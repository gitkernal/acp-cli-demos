VIRTUALS_API_KEY=
VIRTUALS_BASE_URL=https://compute.virtuals.io/v1
VIRTUALS_PROXY_HOST=127.0.0.1
VIRTUALS_PROXY_PORT=8787
# Optional local bearer token for clients that call the proxy.
# VIRTUALS_PROXY_API_KEY=
# Forward Codex max_output_tokens to upstream max_tokens. Disabled by default
# because some Virtuals-hosted models reject token cap parameters.
# VIRTUALS_PROXY_FORWARD_MAX_TOKENS=1
